# Copie en .env et renseigne les valeurs avant `docker compose up -d`.

# Domaine de base. L'UI sera sur https://app.<DOMAIN>, les previews sur
# https://<projet>-<port>.<DOMAIN>.
DOMAIN=example.com

# Token API Cloudflare (permission Zone:DNS:Edit) pour le wildcard DNS-01.
CLOUDFLARE_API_TOKEN=changeme

# Secret d'instance (32+ octets) : chiffrement des clés API au repos.
# Génère-le avec : openssl rand -base64 32
SAWADEV_SECRET=changeme

# Registre et tag des images (par défaut GHCR officiel + latest).
REGISTRY=ghcr.io/sawadev
TAG=latest

# Canal de mise à jour : stable | beta
CHANNEL=stable
